# Langfuse v3 Environment Variables
# Copy to .env and fill in values
# Generate secrets: openssl rand -base64 32 (for NEXTAUTH_SECRET, SALT)
#                   openssl rand -hex 32 (for ENCRYPTION_KEY — must be exactly 64 hex chars)

# Postgres (dedicated instance in this compose)
POSTGRES_PASSWORD=GENERATE_ME

# Auth
NEXTAUTH_SECRET=GENERATE_ME
SALT=GENERATE_ME
ENCRYPTION_KEY=GENERATE_ME_64_HEX_CHARS

# ClickHouse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=GENERATE_ME

# MinIO (S3-compatible)
MINIO_USER=minio
MINIO_PASSWORD=GENERATE_ME_MIN_8_CHARS

# Redis
REDIS_AUTH=GENERATE_ME
